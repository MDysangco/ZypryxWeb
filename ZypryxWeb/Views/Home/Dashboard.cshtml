@using ZypryxWeb.Models.ViewModels
@model HomePageModelView

@{
    ViewData["Title"] = "Zypryx - Dashboard";
}

@{
    var ticker = new List<object>();
    var grouped = Model.Klines
        .GroupBy(k => k.CoinId.Value)
        .ToList();

    foreach (var g in grouped)
    {
        var ordered = g.OrderByDescending(k => k.KlineOpenTime).ToList();
        if (ordered.Count < 2)
            continue;

        var latest = ordered[0];
        var prev = ordered[1];

        decimal latestClose = latest.ClosePrice.Value;
        decimal prevClose = prev.ClosePrice.Value;

        decimal pct = prevClose == 0 ? 0 : ((latestClose - prevClose) / prevClose) * 100;
        bool up = latestClose >= prevClose;

        var coin = Model.Coins.First(c => c.Id == g.Key);

        // Insert slash before USDT
        string sym = coin.Ticker.Replace("USDT", "/USDT");

        ticker.Add(new
        {
            sym = sym,
            price = Math.Round(latestClose, 2),
            chg = $"{Math.Round(pct, 2).ToString()}%",
            up = up
        });
    }

    int tickerCount = ticker.Count;
    int duration = tickerCount * 3;

    // Serialize to JSON for JS
    var tickerJson = System.Text.Json.JsonSerializer.Serialize(ticker);
}

<style>

    .ticker-track {
        display: flex;
        gap: 0;
        white-space: nowrap;
        animation: ticker @($"{duration.ToString()}s") linear infinite;
    }

    /* ── Draw-on animation (stroke) ── */
    .draw {
        fill: none;
        stroke-dasharray: 1000;
        stroke-dashoffset: 1000;
        animation: drawLine 0.7s ease forwards;
    }

    @@keyframes drawLine {
        to {
            stroke-dashoffset: 0;
        }
    }

    /* ── Fade in ── */
    .fade {
        opacity: 0;
        animation: fadeIn 0.4s ease forwards;
    }

    @@keyframes fadeIn {
        to {
            opacity: 1;
        }
    }

    /* ── Individual delays ── */
    .d01 {
        animation-delay: 0.3s;
    }

    .d02 {
        animation-delay: 0.7s;
    }

    .d03 {
        animation-delay: 1.2s;
    }

    .d04 {
        animation-delay: 1.7s;
    }

    .d05 {
        animation-delay: 2.1s;
    }

    .d06 {
        animation-delay: 2.5s;
    }

    .d07 {
        animation-delay: 2.8s;
    }

    .d08 {
        animation-delay: 3.1s;
    }

    .d09 {
        animation-delay: 3.4s;
    }

    .d10 {
        animation-delay: 3.9s;
    }

    .d11 {
        animation-delay: 4.2s;
    }

    .d12 {
        animation-delay: 4.4s;
    }

    .d13 {
        animation-delay: 4.7s;
    }

    /* ── Antenna blink ── */
    .antenna-dot {
        opacity: 0;
        animation: fadeIn 0.2s ease forwards 0.4s, antBlink 1.5s ease-in-out infinite 2.5s;
    }

    @@keyframes antBlink {
        0%, 100% {
            opacity: 1;
            fill: #ff8c00;
        }

        50% {
            opacity: 0.2;
            fill: #ffffff;
        }
    }

    /* ── Eye iris draw + pulse ── */
    .eye-iris {
        fill: none;
        stroke: #ff8c00;
        stroke-width: 1.8;
        stroke-dasharray: 200;
        stroke-dashoffset: 200;
        animation: drawLine 0.7s ease forwards 1.7s, eyePulse 3s ease-in-out infinite 6s;
    }

    @@keyframes eyePulse {
        0%, 100% {
            opacity: 1;
        }

        50% {
            opacity: 0.3;
        }
    }

    /* ── Eye core + blink ── */
    .eye-core {
        opacity: 0;
        animation: fadeIn 0.3s ease forwards 3.0s, coreBlink 2.5s step-end infinite 7s;
    }

    @@keyframes coreBlink {
        0%, 88%, 100% {
            opacity: 1;
        }

        90%, 98% {
            opacity: 0;
        }
    }

    /* ── Status dot blink ── */
    .status-dot {
        opacity: 0;
        animation: fadeIn 0.3s ease forwards 5s, dotBlink 1.2s step-end infinite 5.5s;
    }

    @@keyframes dotBlink {
        0%, 100% {
            opacity: 1;
        }

        50% {
            opacity: 0;
        }
    }

    /* ── Label fade ── */
    .label-text {
        opacity: 0;
        animation: fadeIn 0.5s ease forwards 5.2s;
    }
</style>



<div class="relative flex overflow-hidden w-full h-full">

    <!-- SIDEBAR -->
    <aside class="sidebar">
        <div class="sb-head">
            <span class="sb-title">Markets</span>
            <span class="sb-count" id="coinCount">12</span>
        </div>
        <div class="sb-search">
            <input type="text" id="searchInput" placeholder="Search…" oninput="filterCoins(this.value)">
        </div>
        <div class="sb-label" id="favLabel">★ Favourites</div>
        <div class="coin-list fav-list" id="favList"></div>
        <div class="sb-label">All Markets</div>
        <div class="coin-list all-list" id="allList"></div>
    </aside>

    <main class="chart-main">
        <div class="coin-hd">
            <span class="hd-sym" id="hdSym">—</span>
            <span class="hd-px" id="hdPx">—</span>
            <span class="hd-chg" id="hdChg">—</span>
            <div class="hd-sep"></div>

            <!-- OHLCV live readout -->
            <div class="ohlcv">
                <span class="ov-item"><span class="ov-k">O</span><span class="ov-v" id="oO">—</span></span>
                <span class="ov-item"><span class="ov-k">H</span><span class="ov-v" id="oH">—</span></span>
                <span class="ov-item"><span class="ov-k">L</span><span class="ov-v" id="oL">—</span></span>
                <span class="ov-item"><span class="ov-k">C</span><span class="ov-v" id="oC">—</span></span>
                <span class="ov-item"><span class="ov-k">Vol</span><span class="ov-v" id="oV">—</span></span>
                <span class="ov-item" id="oS"></span>
            </div>

            <!-- TF / Type / Live -->
            <div class="chart-ctrl">
                <button class="tf-btn" onclick="ZC.setTf('1h',this)">1H</button>
                <button class="tf-btn active" onclick="ZC.setTf('4h',this)">4H</button>
                <button class="tf-btn" onclick="ZC.setTf('1d',this)">1D</button>
                <button class="tf-btn" onclick="ZC.setTf('1w',this)">1W</button>
                <div class="sep"></div>
                <button class="ct-btn active" onclick="ZC.setType('candle',this)">Candle</button>
                <button class="ct-btn" onclick="ZC.setType('line',this)">Line</button>
                <div class="sep"></div>
                <button class="live-btn" id="liveBtn" onclick="ZC.jumpToLive()">→ Live</button>
            </div>
        </div>

        <!-- MAIN CHART CANVAS -->
        <div class="chart-wrap" id="chartWrap">
            <canvas id="klineCanvas" style="cursor:crosshair;"></canvas>
            <div class="chart-tip" id="chartTip"></div>
        </div>

        <!-- VOLUME CANVAS -->
        <div class="vol-wrap">
            <canvas id="volCanvas"></canvas>
        </div>

        <!-- SIGNAL LEGEND -->
        <div class="sig-legend">
            <span class="cf-info" id="cfInfo">4H · ZYP-1 Oracle · scroll to zoom · drag to pan</span>
            <div class="sleg-row">
                <span class="sleg">
                    <svg width="8" height="8"><polygon points="4,0 8,8 0,8" fill="#00c98d" /></svg>
                    <span style="color:#00c98d">BUY</span>
                </span>
                <span class="sleg">
                    <svg width="8" height="8"><polygon points="4,8 8,0 0,0" fill="#ff4d4d" /></svg>
                    <span style="color:#ff4d4d">SELL</span>
                </span>
                <span class="sleg">
                    <svg width="8" height="8"><circle cx="4" cy="4" r="3.5" fill="#ff8c00" /></svg>
                    <span style="color:#ff8c00">HOLD</span>
                </span>
            </div>
        </div>

    </main>

    <!-- RIGHT PANEL -->
    <aside class="right-panel" id="rightPanel">

        <!-- COIN OVERVIEW -->
        <div class="rp-sec">
            <div class="rp-title">Coin Overview</div>
            <div class="rp-coin-hd">
                <div class="rp-ico" id="rpIco"></div>
                <div>
                    <div class="rp-price" id="rpPrice">—</div>
                    <div class="rp-chg" id="rpChg">—</div>
                </div>
            </div>
            <div id="rpStats"></div>
        </div>

        <!-- ZYP-1 SIGNAL -->
        <div class="rp-sec">
            <div class="rp-title">ZYP-1 Signal</div>
            <div id="rpSignal"></div>
        </div>

        <!-- TRADE PANEL -->
        <div class="rp-sec trade-section" id="tradeSection">
            <div class="rp-title">Trade</div>
            <div class="trade-tabs">
                <button class="trade-tab buy active" id="buyTab" onclick="setTradeTab('buy',this)">Buy</button>
                <button class="trade-tab sell" onclick="setTradeTab('sell',this)">Sell</button>
            </div>
            <div class="trade-body">
                <div class="ot-row">
                    <button class="ot-btn active" onclick="setOT(this)">Market</button>
                    <button class="ot-btn" onclick="setOT(this)">Limit</button>
                    <button class="ot-btn" onclick="setOT(this)">Stop</button>
                </div>
                <div class="ti-row">
                    <div class="ti-lbl"><span>Amount</span><span class="ti-bal">Balance: 0.00 USDT</span></div>
                    <div class="ti-wrap">
                        <input type="number" id="tradeAmt" placeholder="0.00" oninput="calcTotal()">
                        <span class="ti-unit">USDT</span>
                    </div>
                </div>
                <div class="pct-row">
                    <button class="pct-btn">25%</button>
                    <button class="pct-btn">50%</button>
                    <button class="pct-btn">75%</button>
                    <button class="pct-btn">Max</button>
                </div>
                <div class="ti-row">
                    <div class="ti-lbl"><span>Price (per coin)</span></div>
                    <div class="ti-wrap">
                        <input type="number" id="tradePrice" placeholder="Market price" oninput="calcTotal()">
                        <span class="ti-unit">USDT</span>
                    </div>
                </div>
                <div class="trade-total">
                    <span class="trade-total-k">Estimated Total</span>
                    <span class="trade-total-v" id="tradeTotal">—</span>
                </div>
                <button class="trade-submit buy" id="tradeSubmit">Buy</button>
            </div>

            <!-- COMING SOON OVERLAY -->
            <div class="cs-overlay" id="csOverlay">
                <div class="cs-icon">🔒</div>
                <div class="cs-title">Coming Soon</div>
                <div class="cs-sub">Wallet connection and live trading will be available in the next release of Zypryx.</div>
                <div class="cs-badge">In Development</div>
                <button class="cs-notify">Notify Me</button>
            </div>
        </div>

    </aside>

</div>

@section Scripts {
<script>

    async function getCoinData(coinId) {
        const response = await fetch("/Home/GetCoinData", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ CoinId: coinId })
        });

        const data = await response.json();
        S.candles = convertKlinesToCandles(data);
        ZC.load(S.candles);

        document.getElementById('cfInfo').textContent =
            `${S.tf.toUpperCase()} · ${ZC.disp.length.toLocaleString()} candles · ZYP-1 Oracle · scroll to zoom · drag to pan`;

        const latestSignal = S.candles.slice().reverse().find(c => c.signal)?.signal;
        S.coin.signal = latestSignal || '—';

        updateHeader(S.coin);
        updateRightPanel();
        buildTicker();
    }

    function convertKlinesToCandles(klines) {
        return klines.map(k => ({
            o: k.open,
            h: k.high,
            l: k.low,
            c: k.close,
            v: k.volume,
            signal: k.signal,
            t: k.time,
            pb: k.probBuy,
            ps: k.probSell,
            ph: k.probHold
        }));
    }

    /* ════════════════════════════════
       DATA
    ════════════════════════════════ */
    const model = @Html.Raw(Json.Serialize(Model));
    const COINS = buildUiCoins(model);

    const S = {
      coin: COINS[0],
      tf: '4h',
      chartType: 'candle',
      favs: new Set(['BTC','ETH']),
      showTrade: true,
      candles: [],
      hoverIdx: -1,
      tradeTab: 'buy',
      search: '',
    };

    /* ════════════════════════════════
       FORMATTING
    ════════════════════════════════ */
    function fp(p){
      if(p>=10000) return '$'+p.toLocaleString('en-US',{maximumFractionDigits:0});
      if(p>=1000)  return '$'+p.toLocaleString('en-US',{minimumFractionDigits:2,maximumFractionDigits:2});
      if(p>=1)     return '$'+p.toFixed(2);
      return '$'+p.toFixed(4);
    }
    function fv(p){
        return p>=1 ? p.toFixed(2) : p.toFixed(4);
    }

    /* ════════════════════════════════
       COIN LIST
    ════════════════════════════════ */
    function renderLists(){
      const q = S.search.toLowerCase();
      const filtered = q ? COINS.filter(c=>c.sym.toLowerCase().includes(q)||c.name.toLowerCase().includes(q)) : COINS;
      const favs = filtered.filter(c=>S.favs.has(c.sym));
      const fl=document.getElementById('favLabel');
      fl.style.display = favs.length ? 'block' : 'none';
      document.getElementById('favList').innerHTML  = favs.map(cRow).join('');
      document.getElementById('allList').innerHTML  = filtered.map(cRow).join('');
      document.getElementById('coinCount').textContent = filtered.length;
    }

    function cRow(c){
      const act = c.sym===S.coin.sym;
      const up  = c.chg>=0;
      const fav = S.favs.has(c.sym);
      return `<div class="c-row${act?' active':''}" onclick="selectCoin('${c.sym}')">
        <div class="c-ico" style="background:${c.color}20;color:${c.color};">${c.sym.substring(0,3)}</div>
        <div class="c-mid"><div class="c-sym">${c.sym}</div><div class="c-name">${c.name}</div></div>
        <div class="c-end"><div class="c-price">${fp(c.price)}</div><div class="c-chg ${up?'up':'dn'}">${up?'+':''}${c.chg.toFixed(2)}%</div></div>
        <button class="c-star${fav?' on':''}" onclick="toggleFav(event,'${c.sym}')" title="Favourite">★</button>
      </div>`;
    }

    function selectCoin(sym){
        S.coin = COINS.find(c=> c.sym===sym);
        getCoinData(S.coin.id);
        updateRightPanel();
        renderLists();
    }

    function toggleFav(e,sym){
      e.stopPropagation();
      S.favs.has(sym)?S.favs.delete(sym):S.favs.add(sym);
      renderLists();
    }

    function filterCoins(v){
        S.search=v;
        renderLists();
    }

    /* ════════════════════════════════
       HEADER
    ════════════════════════════════ */
    function updateHeader(c){
      const el = (id, v) => { const e = document.getElementById(id); if(e) e.textContent = v; };
      el('hdSym', c.sym + '/USDT');
      el('hdPx', fp(c.price));
      const ce = document.getElementById('hdChg');
      if(ce){ ce.textContent=(c.chg>=0?'+':'')+c.chg.toFixed(2)+'%'; ce.className='hd-chg '+(c.chg>=0?'up':'dn'); }
    }

    /* ════════════════════════════════
       RIGHT PANEL
    ════════════════════════════════ */
    function updateRightPanel()
    {
      const c=S.coin;

      if (!Array.isArray(S.candles) || S.candles.length === 0) {
          document.getElementById('rpPrice').textContent = '-';
          document.getElementById('rpChg').textContent = '-';
          return;
      }

      const latestCandle = S.candles.reduce((a, b) => a.t > b.t ? a : b);

      let confidence = '-';
      switch (latestCandle.signal) {
        case 'HOLD': confidence = latestCandle.ph * 100; break;
        case 'BUY':  confidence = latestCandle.pb * 100; break;
        case 'SELL': confidence = latestCandle.ps * 100; break;
        default: break;
      }

      const confText = confidence === null ? '-' : confidence.toFixed(2) + '%';

      document.getElementById('rpIco').style.cssText=`background:${c.color}20;color:${c.color};`;
      document.getElementById('rpIco').textContent=c.sym.substring(0,3);
      document.getElementById('rpPrice').textContent=fp(c.price);
      const rc=document.getElementById('rpChg');
      rc.textContent=(c.chg>=0?'+':'')+c.chg.toFixed(2)+'% today';
      rc.className='rp-chg '+(c.chg>=0?'up':'dn');

      document.getElementById('rpStats').innerHTML=`
        <div class="kv"><span class="kv-k">Market Cap</span><span class="kv-v">${c.mcap}</span></div>
        <div class="kv"><span class="kv-k">24h Volume</span><span class="kv-v">${c.vol}</span></div>
        <div class="kv"><span class="kv-k">24h High</span><span class="kv-v up">${fp(c.h24)}</span></div>
        <div class="kv"><span class="kv-k">24h Low</span><span class="kv-v dn">${fp(c.l24)}</span></div>
        <div class="kv"><span class="kv-k">Circulating</span><span class="kv-v">${c.supply}</span></div>
        <div class="kv"><span class="kv-k">Rank</span><span class="kv-v og">N/A</span></div>
      `;

      const sc=c.signal==='BUY'?'sig-buy':c.signal==='SELL'?'sig-sell':'sig-hold';
      document.getElementById('rpSignal').innerHTML=`
        <div class="sig-box ${sc}">
          <div>
            <div style="font-size:7px;letter-spacing:2px;color:rgba(255,255,255,.25);margin-bottom:2px;">ZYP-1 ORACLE</div>
            <div class="sig-label">${c.signal}</div>
          </div>
          <div class="sig-meta">
            <div class="sig-cf-lbl">Confidence</div>
            <div class="sig-cf-val">${confText}%</div>
          </div>
        </div>
      `;

      document.getElementById('tradeSubmit').textContent=(S.tradeTab==='buy'?'Buy ':'Sell ')+c.sym;
      document.getElementById('tradeSubmit').className='trade-submit '+S.tradeTab;
    }

    /* ════════════════════════════════
       TRADE PANEL
    ════════════════════════════════ */
    function setTradeTab(tab,btn){
      S.tradeTab=tab;
      document.querySelectorAll('.trade-tab').forEach(b=>b.classList.remove('active'));
      btn.classList.add('active');
      const sub=document.getElementById('tradeSubmit');
      sub.className='trade-submit '+tab;
      sub.textContent=(tab==='buy'?'Buy ':'Sell ')+S.coin.sym;
    }

    function setOT(btn){
      document.querySelectorAll('.ot-btn').forEach(b=>b.classList.remove('active'));
      btn.classList.add('active');
    }

    function calcTotal(){
      const amt=parseFloat(document.getElementById('tradeAmt').value)||0;
      const price=parseFloat(document.getElementById('tradePrice').value)||S.coin.price;
      if(amt>0){
        const total=(amt/price)*price;
        document.getElementById('tradeTotal').textContent='$'+total.toFixed(2)+' USDT';
      } else {
        document.getElementById('tradeTotal').textContent='—';
      }
    }

    /* ════════════════════════════════
       TICKER
    ════════════════════════════════ */
    function buildTicker(){
      const items=[...COINS,...COINS].map(c=>`
        <span class="ticker-item">
          <span class="coin">${c.sym}</span>
          <span class="price">${fp(c.price)}</span>
          <span class="${c.chg>=0?'up':'down'}">${c.chg>=0?'+':''}${c.chg.toFixed(2)}%</span>
        </span>
      `).join('');
      document.getElementById('tickerTrack').innerHTML=items;
    }

    /* ════════════════════════════════
       CLOCK
    ════════════════════════════════ */
    function tickClock(){
      const n=new Date(),p=x=>String(x).padStart(2,'0');
      const el=document.getElementById('navClock');
      if(el) el.textContent=p(n.getUTCHours())+':'+p(n.getUTCMinutes())+':'+p(n.getUTCSeconds())+' UTC';
    }

    /* ════════════════════════════════
       NAV TABS
    ════════════════════════════════ */
    document.querySelectorAll('.nav-tab').forEach(btn=>{
      btn.addEventListener('click',()=>{
        document.querySelectorAll('.nav-tab').forEach(b=>b.classList.remove('active'));
        btn.classList.add('active');
      });
    });

    /* ════════════════════════════════
       INIT
    ════════════════════════════════ */
    const ZC = new ZypChart({ main:'klineCanvas', vol:'volCanvas', tip:'chartTip' });

    window.addEventListener('load',()=>{
        renderLists();
        updateHeader(S.coin);
        updateRightPanel();
        buildTicker();
        getCoinData(S.coin.id);
        setInterval(tickClock, 1000);
    });

</script>
}
