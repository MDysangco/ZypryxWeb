@section Scripts {
<script>
    document.addEventListener("DOMContentLoaded", () => {

        /* UTC clock */
        function tick() {
        const n = new Date(), p = x => String(x).padStart(2, '0');
        const el = document.getElementById('utcClock');
        if (el) el.textContent = p(n.getUTCHours()) + ':' + p(n.getUTCMinutes()) + ':' + p(n.getUTCSeconds()) + ' UTC';
        }
        tick(); setInterval(tick, 1000);

        const coins = @Html.Raw(tickerJson);

        // Shared renderer lives in site.js (formats BTC/USDT, $ price, ± %).
        buildTicker(coins);

        /* Nav scroll-spy — highlights the link for the section in view.
           Smooth panning itself is handled by CSS scroll-behavior + the anchor hrefs. */
        const navLinks = Array.from(document.querySelectorAll('.nav-links a[href^="#"]'));
        const spied = navLinks
            .map(a => document.querySelector(a.getAttribute('href')))
            .filter(Boolean);

        if ('IntersectionObserver' in window && spied.length) {
            const spy = new IntersectionObserver((entries) => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        const id = '#' + entry.target.id;
                        navLinks.forEach(a => a.classList.toggle('active', a.getAttribute('href') === id));
                    }
                });
            }, { rootMargin: '-45% 0px -50% 0px', threshold: 0 });
            spied.forEach(s => spy.observe(s));
        }

      });
</script>
}
