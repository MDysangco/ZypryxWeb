@using ZypryxWeb.Models.ViewModels
@model HomePageModelView;

@{
    ViewData["Title"] = "Zypryx";
    ViewData["BodyClass"] = "page-home";
}

@{
    var ticker = new List<object>();
    var grouped = Model.Klines
        .GroupBy(k => k.CoinId.Value)
        .ToList();

    foreach (var g in grouped)
    {
        var ordered = g.OrderByDescending(k => k.KlineOpenTime).ToList();
        if (ordered.Count < 2)
            continue;

        var latest = ordered[0];
        var prev = ordered[1];

        decimal latestClose = latest.ClosePrice.Value;
        decimal prevClose = prev.ClosePrice.Value;

        decimal pct = prevClose == 0 ? 0 : ((latestClose - prevClose) / prevClose) * 100;

        var coin = Model.Coins.First(c => c.Id == g.Key);

        // Raw ticker + numeric values — display formatting (BTC/USDT pair, $ price,
        // ± %) is handled by the shared buildTicker() in site.js.
        ticker.Add(new
        {
            sym = coin.Ticker,
            price = Math.Round(latestClose, 2),
            chg = Math.Round(pct, 2)
        });
    }

    var tickerJson = System.Text.Json.JsonSerializer.Serialize(ticker);
}

<style>

    /* ── Draw-on animation (stroke) ── */
    .draw {
        fill: none;
        stroke-dasharray: 1000;
        stroke-dashoffset: 1000;
        animation: drawLine 0.7s ease forwards;
    }

    @@keyframes drawLine {
        to {
            stroke-dashoffset: 0;
        }
    }

    /* ── Fade in ── */
    .fade {
        opacity: 0;
        animation: fadeIn 0.4s ease forwards;
    }

    @@keyframes fadeIn {
        to {
            opacity: 1;
        }
    }

    /* ── Individual delays ── */
    .d01 {
        animation-delay: 0.3s;
    }

    .d02 {
        animation-delay: 0.7s;
    }

    .d03 {
        animation-delay: 1.2s;
    }

    .d04 {
        animation-delay: 1.7s;
    }

    .d05 {
        animation-delay: 2.1s;
    }

    .d06 {
        animation-delay: 2.5s;
    }

    .d07 {
        animation-delay: 2.8s;
    }

    .d08 {
        animation-delay: 3.1s;
    }

    .d09 {
        animation-delay: 3.4s;
    }

    .d10 {
        animation-delay: 3.9s;
    }

    .d11 {
        animation-delay: 4.2s;
    }

    .d12 {
        animation-delay: 4.4s;
    }

    .d13 {
        animation-delay: 4.7s;
    }

    /* ── Antenna blink ── */
    .antenna-dot {
        opacity: 0;
        animation: fadeIn 0.2s ease forwards 0.4s, antBlink 1.5s ease-in-out infinite 2.5s;
    }

    @@keyframes antBlink {
        0%, 100% {
            opacity: 1;
            fill: #ff8c00;
        }

        50% {
            opacity: 0.2;
            fill: #ffffff;
        }
    }

    /* ── Eye iris draw + pulse ── */
    .eye-iris {
        fill: none;
        stroke: #ff8c00;
        stroke-width: 1.8;
        stroke-dasharray: 200;
        stroke-dashoffset: 200;
        animation: drawLine 0.7s ease forwards 1.7s, eyePulse 3s ease-in-out infinite 6s;
    }

    @@keyframes eyePulse {
        0%, 100% {
            opacity: 1;
        }

        50% {
            opacity: 0.3;
        }
    }

    /* ── Eye core + blink ── */
    .eye-core {
        opacity: 0;
        animation: fadeIn 0.3s ease forwards 3.0s, coreBlink 2.5s step-end infinite 7s;
    }

    @@keyframes coreBlink {
        0%, 88%, 100% {
            opacity: 1;
        }

        90%, 98% {
            opacity: 0;
        }
    }

    /* ── Status dot blink ── */
    .status-dot {
        opacity: 0;
        animation: fadeIn 0.3s ease forwards 5s, dotBlink 1.2s step-end infinite 5.5s;
    }

    @@keyframes dotBlink {
        0%, 100% {
            opacity: 1;
        }

        50% {
            opacity: 0;
        }
    }

    /* ── Label fade ── */
    .label-text {
        opacity: 0;
        animation: fadeIn 0.5s ease forwards 5.2s;
    }

    /* ── Zypryx wordmark: an old, broken light that flickers on, then holds a steady glow ── */
    .zypryx-wordmark {
        animation: signFlicker 3.2s linear both;
        filter:
            drop-shadow(0 0 2px rgba(255, 255, 255, 0.95))
            drop-shadow(0 0 10px rgba(255, 140, 0, 0.85))
            drop-shadow(0 0 24px rgba(255, 140, 0, 0.6))
            drop-shadow(0 0 48px rgba(255, 140, 0, 0.4));
        will-change: opacity;
    }

    @@keyframes signFlicker {
        /* erratic struggle to ignite */
        0%   { opacity: 0; }
        3%   { opacity: 0.12; }
        5%   { opacity: 0; }
        9%   { opacity: 0.7; }
        11%  { opacity: 0.15; }
        13%  { opacity: 0.9; }
        15%  { opacity: 0.2; }
        18%  { opacity: 0; }
        22%  { opacity: 1; }
        24%  { opacity: 0.3; }
        26%  { opacity: 0.95; }
        29%  { opacity: 0.1; }
        32%  { opacity: 0.85; }
        36%  { opacity: 0; }
        40%  { opacity: 1; }
        43%  { opacity: 0.45; }
        45%  { opacity: 1; }
        49%  { opacity: 0.25; }
        53%  { opacity: 0.95; }
        /* settling — fewer, weaker dropouts */
        57%  { opacity: 0.55; }
        61%  { opacity: 1; }
        66%  { opacity: 0.7; }
        70%  { opacity: 1; }
        74%  { opacity: 0.4; }
        77%  { opacity: 1; }
        82%  { opacity: 0.8; }
        86%  { opacity: 1; }
        91%  { opacity: 0.9; }
        95%  { opacity: 1; }
        100% { opacity: 1; }
    }

    /* ── Homepage layout: page scrolls, footer pinned to bottom of the viewport ── */
    html {
        scroll-behavior: smooth;
    }

    body.page-home .app-shell {
        height: auto;
        min-height: 100vh;
    }

    /* Full-width navbar/footer, but keep the homepage body capped and centred */
    body.page-home .app-body {
        max-width: 1920px;
        margin-inline: auto;
    }

    body.page-home main[role="main"],
    body.page-home main[role="main"] > div {
        height: auto;
    }

    body.page-home .hud-bar {
        position: fixed;
        left: 0;
        right: 0;
        bottom: 0;
        background: rgba(8, 8, 8, 0.92);
        -webkit-backdrop-filter: blur(6px);
        backdrop-filter: blur(6px);
        z-index: 40;
    }

    /* Offset anchored sections so they clear the sticky navbar when panned to */
    section[id] {
        scroll-margin-top: 140px;
    }

    /* ── Signals + About sections ── */
    .signals-intro,
    .about-text {
        color: rgba(255, 255, 255, 0.45);
        font-size: 14px;
        line-height: 1.9;
        letter-spacing: 0.4px;
        max-width: 760px;
        margin-bottom: 20px;
    }

    .signal-card {
        background: var(--panel);
        border: 1px solid rgba(255, 255, 255, 0.06);
        border-top: 2px solid var(--orange);
        padding: 26px 24px;
        transition: transform 0.3s, border-color 0.3s, background 0.3s;
    }

    .signal-card:hover {
        transform: translateY(-4px);
        border-color: var(--border);
        background: rgba(255, 140, 0, 0.03);
    }

    .signal-card.buy {
        border-top-color: #00c98d;
    }

    .signal-card.hold {
        border-top-color: #ff8c00;
    }

    .signal-card.sell {
        border-top-color: #ff4d4d;
    }

    .signal-glyph {
        width: 34px;
        height: 34px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 16px;
    }

    .signal-name {
        font-family: var(--font-display);
        font-size: 15px;
        font-weight: 900;
        letter-spacing: 2px;
        margin-bottom: 8px;
    }

    .signal-card.buy .signal-name {
        color: #00c98d;
    }

    .signal-card.hold .signal-name {
        color: #ff8c00;
    }

    .signal-card.sell .signal-name {
        color: #ff4d4d;
    }

    .signal-desc {
        font-size: 12px;
        color: rgba(255, 255, 255, 0.4);
        line-height: 1.8;
        letter-spacing: 0.4px;
    }

    .signals-tick {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        margin-top: 28px;
        padding: 8px 14px;
        border: 1px solid rgba(255, 140, 0, 0.2);
        background: rgba(255, 140, 0, 0.04);
        font-family: var(--font-mono);
        font-size: 9px;
        letter-spacing: 2px;
        text-transform: uppercase;
        color: rgba(255, 140, 0, 0.7);
    }

    .signals-tick-dot {
        width: 6px;
        height: 6px;
        border-radius: 50%;
        background: #ff8c00;
        animation: dotBlink 1.2s step-end infinite;
        flex-shrink: 0;
    }

    .about-chip {
        display: flex;
        align-items: center;
        gap: 10px;
        background: var(--panel);
        border: 1px solid rgba(255, 255, 255, 0.06);
        border-left: 2px solid var(--orange);
        padding: 14px 18px;
        font-family: var(--font-mono);
        font-size: 11px;
        letter-spacing: 1px;
        color: rgba(255, 255, 255, 0.6);
    }

</style>


