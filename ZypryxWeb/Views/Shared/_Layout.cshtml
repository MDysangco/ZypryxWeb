<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ZypryxWeb</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/src/styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&family=Share+Tech+Mono&display=swap" rel="stylesheet">

</head>
<body class="bg-black">

    <div class="container max-w-[1920px] h-screen mx-auto flex flex-col">

        <nav class="navbar flex-shrink-0 flex flex-col justify-between items-center bg-black gap-5 sm:gap-8 z-11 sm:px-10 pt-6 sm:pt-10 sticky top-0 w-full">

            <div class="flex flex-row justify-between items-center bg-black z-11 w-full">
                <a href="/" class="nav-logo flex flex-row gap-2">
                    <svg class="nav-logo-mark" width="28" height="28" viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <rect x="2" y="2" width="24" height="6" fill="#ffffff" />
                        <polygon points="26,8 18,8 2,20 2,26 10,26" fill="#ff8c00" />
                        <rect x="2" y="20" width="24" height="6" fill="#ffffff" />
                        <polygon points="18,8 26,8 26,2 2,2 2,8" fill="#ffffff" />
                        <polygon points="2,20 10,20 2,26" fill="#ffffff" />
                    </svg>
                    <span class="orbitron nav-logo-word text-white m-auto">
                        Zy<span class="theme-orange">p</span>ryx
                    </span>
                </a>

                <ul class="nav-links hidden lg:flex flex-row gap-10">
                    <li><a class="light-grey orbitron text-sm" href="#features">FEATURES</a></li>
                    <li><a class="light-grey orbitron text-sm" href="#pricing">PRICING</a></li>
                    <li><a class="light-grey orbitron text-sm" href="#signals">SIGNALS</a></li>
                    <li><a class="light-grey orbitron text-sm" href="#about">ABOUT</a></li>
                </ul>

                <div class="nav-auth hidden lg:flex">
                    <a href="/dashboard" class="cta-primary">Launch App</a>
                </div>
            
                <span class="theme-orange block z-10 lg:hidden" style="font-size:30px;cursor:pointer" onclick="toggleNav()">&#9776;</span>

                <div id="mySidenav" class="sidenav">
                    <a href="#">About</a>
                    <a href="#">Services</a>
                    <a href="#">Clients</a>  
                    <a href="#">Contact</a>
                </div>

            </div>

            <div class="ticker-bar">
                <div class="ticker-label">LIVE</div>
                <div class="ticker-track" id="tickerTrack">
                    <!-- Populated by JS -->
                </div>
            </div>

        </nav>

        <!-- Ambient layers -->
        <div class="grid-bg"></div>
        <div class="scanline"></div>
        <div class="corner tl"></div>
        <div class="corner tr"></div>
        <div class="corner bl"></div>
        <div class="corner br"></div>

     
        <div class="w-full flex-1 min-h-0">
            <main role="main" class="h-full">
                @RenderBody()
            </main>
        </div>

        <footer class="hud-bar flex-shrink-0">
            <span>SYS · ZYPRYX v1.0</span>
            <span id="utcClock">--:--:-- UTC</span>
            <span>PRED ENGINE · ACTIVE</span>
        </footer>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
